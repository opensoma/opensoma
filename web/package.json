    "@tailwindcss/postcss": "latest",
    "clsx": "latest",
    "iron-session": "latest",
    "next": "15",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "latest",
    "tailwind-merge": "latest",
    "tailwindcss": "latest"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
