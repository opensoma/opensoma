{
  "$schema": "https://webreel.dev/schema/v1.json",
  "outDir": "videos/",
  "baseUrl": "http://localhost:6933",
  "viewport": { "width": 800, "height": 900 },
  "defaultDelay": 500,
  "clickDwell": 250,
  "videos": {
    "date-picker": {
      "url": "/design/date-picker",
      "waitFor": "h1",
      "output": "date-picker-demo.mp4",
      "steps": [
        { "action": "pause", "ms": 1000, "description": "Show the design page" },

        { "action": "click", "text": "날짜를 선택하세요", "delay": 700, "description": "Open default date picker" },
        { "action": "pause", "ms": 600, "description": "Show calendar popup" },

        { "action": "click", "text": "20", "delay": 500, "description": "Select day 20" },
        { "action": "pause", "ms": 1000, "description": "Show selected date" },

        {
          "action": "click",
          "text": "2025년 1월 15일",
          "within": ".grid",
          "delay": 700,
          "description": "Open controlled picker"
        },
        { "action": "pause", "ms": 500 },

        {
          "action": "click",
          "selector": "nav button:first-child",
          "delay": 500,
          "description": "Navigate to previous month"
        },
        { "action": "pause", "ms": 300 },
        {
          "action": "click",
          "selector": "nav button:first-child",
          "delay": 500,
          "description": "Navigate to previous month again"
        },
        { "action": "pause", "ms": 300 },

        { "action": "click", "text": "25", "delay": 500, "description": "Select day 25" },
        { "action": "pause", "ms": 1200, "description": "Show updated controlled value" },

        { "action": "click", "text": "2025년 6월 1일", "delay": 700, "description": "Open default value picker" },
        { "action": "pause", "ms": 500, "description": "Show calendar with June" },
        { "action": "click", "selector": "nav button:last-child", "delay": 400, "description": "Go to next month" },
        { "action": "pause", "ms": 300 },
        { "action": "click", "text": "10", "delay": 500, "description": "Select day 10" },
        { "action": "pause", "ms": 800 },

        { "action": "moveTo", "text": "2025년 3월 20일", "description": "Hover over disabled picker" },
        { "action": "pause", "ms": 1200, "description": "Show disabled state" },

        { "action": "pause", "ms": 800, "description": "Final view" }
      ]
    }
  }
}
