{
  "name": "opensoma",
  "version": "0.5.1",
  "description": "SWMaestro MyPage CLI & SDK for AI agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opensoma/opensoma.git"
  },
  "bin": {
    "opensoma": "dist/src/cli.js"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "typesVersions": {
    "*": {
      ".": [
        "./src/index.ts"
      ]
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "default": "./src/constants.ts"
    },
    "./shared/utils/mentoring-params": {
      "types": "./src/shared/utils/mentoring-params.ts",
      "default": "./src/shared/utils/mentoring-params.ts"
    },
    "./shared/utils/team-params": {
      "types": "./src/shared/utils/team-params.ts",
      "default": "./src/shared/utils/team-params.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias --resolve-full-paths",
    "postbuild": "bun scripts/postbuild.ts",
    "test": "bun scripts/test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "prepublishOnly": "bun run build && bun scripts/prepublish.ts",
    "postpublish": "git checkout package.json"
  },
  "dependencies": {
    "better-sqlite3": "latest",
    "commander": "latest",
    "node-html-parser": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/bun": "latest",
    "@types/node": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsc-alias": "^1.8.16",
    "typescript": "latest"
  }
}
