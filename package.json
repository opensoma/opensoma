{
  "name": "opensoma-monorepo",
  "version": "0.1.3",
  "private": true,
  "description": "SWMaestro MyPage CLI & SDK monorepo",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "format": "bun run --filter '*' format",
    "dev:web": "bun run --cwd apps/web dev",
    "test": "bun run --filter '*' test",
    "link": "bun link --cwd packages/opensoma",
    "unlink": "bun unlink --cwd packages/opensoma"
  }
}
